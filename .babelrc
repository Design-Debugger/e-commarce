{
  "presets": ["next/babel"],
  "plugins": [
    [
      "react-dev-inspector/plugins/babel",
      {
        "excludes": [
          "node_modules/**/*"
        ]
      }
    ]
  ],
  "env": {
    "development": {
      "plugins": [
        [
          "react-dev-inspector/plugins/babel",
          {
            "excludes": [
              "node_modules/**/*"
            ]
          }
        ]
      ]
    },
    "production": {
      "plugins": []
    }
  }
}
